# ── Application ─────────────────────────────────────────────
APP_NAME=Jojoba Economic Advisor
APP_VERSION=2.0.0
ENVIRONMENT=development        # development | production
DEBUG=true                     # enables /docs and permissive CORS
API_HOST=0.0.0.0
API_PORT=8000
RELOAD=false

# ── Database ────────────────────────────────────────────────
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_URL_2=                   # production MongoDB URI (used when ENVIRONMENT=production)
DB_NAME=llmautomationai

# ── Security ────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
API_KEY=                       # optional: X-API-Key for service-to-service calls
N8N_WEBHOOK_TOKEN=             # shared secret between backend and n8n

# ── LLM ─────────────────────────────────────────────────────
GROQ_API_KEY=                  # required

# ── RAG / data processing ───────────────────────────────────
DATA_DIR=data/raw
CHUNK_SIZE=1024
CHUNK_OVERLAP=200
MAX_RETRIES=3

# ── Rate limiting ───────────────────────────────────────────
RATE_LIMIT=100
RATE_LIMIT_PERIOD=60

# ── Email (SMTP) ────────────────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── WhatsApp (WAHA) ─────────────────────────────────────────
WAHA_ENABLED=false
WAHA_URL=http://localhost:3000
WAHA_API_KEY=
WHATSAPP_VERIFY_TOKEN=

# ── n8n ─────────────────────────────────────────────────────
N8N_WEBHOOK_URL=

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://jojobanews.vercel.app

# ── Secret encryption (n8n keys, etc.) ──────────────────────
# Dedicated key for encrypting user secrets at rest. Set a long random string.
# If unset, falls back to SECRET_KEY (works, but rotating JWT then breaks stored secrets).
ENCRYPTION_KEY=

# ── This backend's public URL (as n8n must reach it) ────────
# HF Spaces: https://<user>-<space>.hf.space  |  local docker: http://host.docker.internal:8000
PUBLIC_BASE_URL=http://localhost:8000
# Default n8n instance base users see pre-filled (they can override per-account):
N8N_DEFAULT_BASE_URL=https://app.n8n.cloud

# ── RAG model / collection ──────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
CHROMA_COLLECTION=my_collection
GROQ_MODEL=llama-3.3-70b-versatile
SIMILARITY_TOP_K=8

# ── RAG advanced features (all default ON; toggle per stage) ─
HYBRID_ENABLED=true
HYBRID_ALPHA=0.5              # 1.0=dense only, 0.0=BM25 only
RERANK_ENABLED=true
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
RERANK_TOP_N=4
ADAPTIVE_TOP_K=true
QUERY_REWRITE_ENABLED=true
COMPRESSION_ENABLED=true
GROUNDEDNESS_ENABLED=true
GROUNDEDNESS_THRESHOLD=0.35

# ── Semantic cache ──────────────────────────────────────────
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.93

# ── Observability (OpenTelemetry) ───────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=jojoba-advisor
OTEL_EXPORTER_OTLP_ENDPOINT=   # e.g. http://localhost:4318/v1/traces (Jaeger/Tempo)
